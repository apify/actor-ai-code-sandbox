{
    "name": "apify-ai-sandbox",
    "version": "0.0.1",
    "type": "module",
    "description": "Apify AI Code Sandbox for running AI coding operations in a containerized environment.",
    "engines": {
        "node": ">=20.0.0"
    },
    "dependencies": {
        "@modelcontextprotocol/sdk": "^1.29.0",
        "@types/archiver": "^8.0.0",
        "@types/mime-types": "^3.0.1",
        "apify": "^3.7.2",
        "archiver": "^8.0.0",
        "ejs": "^6.0.1",
        "express": "^5.2.1",
        "http-proxy": "^1.18.1",
        "mime-types": "^3.0.2",
        "node-html-markdown": "^2.0.0",
        "node-html-parser": "^7.1.0",
        "zod": "^4.4.3"
    },
    "devDependencies": {
        "@apify/eslint-config": "^2.0.6",
        "@apify/tsconfig": "^0.1.2",
        "@types/ejs": "^3.1.5",
        "@types/express": "^5.0.6",
        "@types/http-proxy": "^1.17.17",
        "@types/node": "^25.9.2",
        "eslint": "^9.39.4",
        "eslint-config-prettier": "^10.1.8",
        "globals": "^17.6.0",
        "prettier": "^3.8.3",
        "tsx": "^4.22.4",
        "typescript": "^6.0.3",
        "typescript-eslint": "^8.61.0"
    },
    "scripts": {
        "start": "npm run start:dev",
        "start:local": "MODE=local npm run start:dev",
        "start:prod": "node dist/main.js",
        "start:dev": "tsx src/main.ts",
        "start:standby": "APIFY_META_ORIGIN=\"STANDBY\" npm run start:dev",
        "build": "tsc -p tsconfig.build.json && npm run copy-templates",
        "copy-templates": "mkdir -p dist/templates && cp src/templates/*.ejs src/templates/*.css dist/templates/",
        "lint": "eslint",
        "lint:fix": "eslint --fix",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "test": "npm run test:unit && npm run test:e2e",
        "test:unit": "node --import tsx --test tests/unit/*.test.ts",
        "test:e2e": "tsx tests/e2e.ts"
    },
    "author": "It's not you it's me",
    "license": "ISC"
}
